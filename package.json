{
  "name": "frankgp-nodejs",
  "version": "0.0.1",
  "description": "Awesome project developed with TypeORM.",
  "type": "commonjs",
  "scripts": {
    "nodemon": "npx nodemon",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "dev": "ts-node-dev --respawn src/main.ts",
    "mono": "nodemon --exec ts-node ./mono/mono.ts",
    "build": "node scripts/clean-dist.js && tsc",
    "build2": "tsc",
    "seed": "ts-node src/seed/seeder.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@nestjs/mapped-types": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.14.0",
    "nanoid": "^3.3.11",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.2.2",
    "typeorm": "0.3.23"
  }
}
